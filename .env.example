# Copy this file to .env and fill in your values
# .env is git-ignored — never commit real secrets

# ── Claude Vision API ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OCR model ─────────────────────────────────────────────────────────────
# "claude"  → Claude Vision (default, requires ANTHROPIC_API_KEY)
# "surya"   → Surya self-hosted fallback (requires SURYA_ENABLED=true)
OCR_MODEL=claude

# ── Surya fallback (optional) ─────────────────────────────────────────────
# SURYA_ENABLED=true
# SURYA_LANG=en

# ── PDF render quality ────────────────────────────────────────────────────
PDF_DPI=200

# ── Database (local dev — docker-compose sets DATABASE_URL automatically) ─
# DATABASE_URL is set by docker-compose; only set it here for direct runs
# DATABASE_URL=postgresql://ocr:ocr@localhost:5432/ocrdb

# ── AWS (only needed for sqs_worker.py / production) ─────────────────────
# AWS_DEFAULT_REGION=us-east-1
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/569239323358/ocr-jobs.fifo

# ── AWS DB credentials (ECS production — omit if using DATABASE_URL) ──────
# DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:569239323358:secret:ocr-pipeline/db-credentials-7dbJsg
# DB_HOST=ocrdb.cluster-cg50w40uytey.us-east-1.rds.amazonaws.com
# DB_NAME=ocrdb
# DB_PORT=5432
