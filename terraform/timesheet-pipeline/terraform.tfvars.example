aws_region           = "us-east-2"
upload_bucket_name   = "timesheets-pdf-uploads-01"
raw_json_bucket_name = "timesheet-scanned-raw-json01"

# Secrets — copy this file to terraform.tfvars and fill in real values
# Never commit terraform.tfvars
anthropic_api_key = "sk-ant-..."
